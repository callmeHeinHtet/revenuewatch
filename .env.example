# --- Database connections (read-only revenue queries) ---
# Aung Naing Thu Hotel — its real production Neon DB.
ANT_DATABASE_URL="postgresql://...neon.tech/...?sslmode=require"

# RestroFlow — MUST be the PRODUCTION Neon branch (ep-lively-unit), NOT the
# local dev branch (ep-autumn-waterfall). Get it from Brain Vault/_secrets/secrets.md
# or the RestroFlow Vercel project env (DATABASE_URL).
RESTROFLOW_DATABASE_URL="postgresql://...neon.tech/...?sslmode=require"

# --- Site password (HTTP Basic Auth) ---
# Any username works; this is the password. If unset, the site is OPEN.
DASHBOARD_PASSWORD="change-me"
